# docker-compose (root) — copy to .env and adjust

# Published host ports
AI_SERVICE_PORT=8000
BACKEND_PORT=8080
FRONTEND_PORT=3000
POSTGRES_PORT=5432

POSTGRES_DB=car_damage
POSTGRES_USER=car_damage
POSTGRES_PASSWORD=car_damage
DB_URL=jdbc:postgresql://postgres:5432/car_damage
DB_USER=car_damage
DB_PASS=car_damage
DB_DRIVER=org.postgresql.Driver

# AI service: yolo for real inference
INFERENCE_MODE=yolo
# Default mounted checkpoint from repo: ./model-training/pretrained/yolo26x.pt
# For trained damage model use: /weights/car_damage_best.pt with docker-compose.model-weights.example.yml
MODEL_PATH=/weights/yolo26x.pt

# Comma-separated origins for FastAPI CORS inside the container
CORS_ORIGINS=*

# Backend -> AI URL inside Docker network
AI_SERVICE_URL=http://ai-service:8000

# Training orchestration (backend -> ai-service /train/*)
TRAIN_MODEL_PATH=/workspace/model-training/cache/base-weights/yolov8m.pt
TRAIN_EPOCHS=30
TRAIN_IMGSZ=640
TRAIN_PROJECT=/workspace/model-training/runs
TRAIN_RUN_NAME=cardd_6class
TRAIN_PATIENCE=15
TRAIN_DEPLOY_PATH=/docker-weights/car_damage_best.pt

# Chat assistant mode:
# - assistant_full: general assistant + analytics routing (recommended)
# - ollama_hybrid: deterministic analytics + optional local ollama router
# - analytics_only: deterministic SQL analytics only
CHAT_MODE=assistant_full
OLLAMA_PORT=11434
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
ALLOW_GENERIC_YOLO_DAMAGE_HEURISTIC=false
