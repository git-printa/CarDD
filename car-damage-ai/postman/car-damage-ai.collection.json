        {
          "name": "POST /predict (valid image)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('has expected keys', function () {",
                  "  pm.expect(body).to.have.property('detections');",
                  "  pm.expect(body).to.have.property('part_detections');",
                  "  pm.expect(body).to.have.property('image_width');",
