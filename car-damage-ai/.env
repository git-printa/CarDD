# docker-compose — copy from .env.example or edit as needed

AI_SERVICE_PORT=8000
BACKEND_PORT=8080
FRONTEND_PORT=3000
ALLOW_GENERIC_YOLO_DAMAGE_HEURISTIC=true

# Real YOLO inference.
# Current model is a generic detector (yolo26x); backend applies fallback mapping to damage types.
# Replace MODEL_PATH with your trained best.pt (scratch/dent/crack) for production-grade estimates.
INFERENCE_MODE=yolo
MODEL_PATH=/docker-weights/car_damage_best.pt

CORS_ORIGINS=*
AI_SERVICE_URL=http://ai-service:8000
CHAT_MODE=assistant_full
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
