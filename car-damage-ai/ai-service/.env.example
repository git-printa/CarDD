# mock = synthetic scratch/dent/crack boxes (no custom weights)
# yolo = Ultralytics YOLO (default for docker-compose; labels match the checkpoint)
INFERENCE_MODE=yolo

# Used when INFERENCE_MODE=yolo (Ultralytics resolves/downloads the name on first load)
MODEL_PATH=yolov8n.pt

# Bind (Docker overrides via command)
HOST=0.0.0.0
PORT=8000
